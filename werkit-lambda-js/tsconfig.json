{
  "compilerOptions": {
    "target": "esnext",
    "lib": ["esnext"],
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "module": "esnext",
    "moduleResolution": "node",
    "outDir": "dist/",
    "sourceMap": true,
    "strict": true,
    "declaration": true
  },
  "include": ["src"],
  "exclude": ["node_modules"]
}
