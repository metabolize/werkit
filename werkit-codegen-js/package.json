{
  "name": "werkit-codegen",
  "version": "0.1.0",
  "description": "Code generation utilities for Werkit",
  "main": "dist",
  "bin": "dist/cli.js",
  "types": "dist",
  "type": "module",
  "scripts": {
    "prebuild": "del dist",
    "build": "tsc",
    "postbuild": "shebang-trim dist/cli.js",
    "prepublishOnly": "npm run build",
    "test": "mocha \"src/*.test.ts\" \"src/**/*.test.ts\"",
    "typecheck": "tsc --noEmit"
  },
  "files": [
    "CHANGELOG.md",
    "dist"
  ],
  "author": "Metabolize",
  "license": "MIT",
  "repository": "metabolize/werkit",
  "keywords": [
    "devops",
    "computation",
    "compute"
  ],
  "dependencies": {
    "argparse": "^2.0.1",
    "werkit": "^0.38.0"
  },
  "devDependencies": {
    "@types/argparse": "2.0.17",
    "@types/node": "22.19.15",
    "@types/chai-as-promised": "8.0.2",
    "@types/chai": "5.2.3",
    "@types/chai-string": "1.4.5",
    "@types/mocha": "10.0.10",
    "chai": "6.2.2",
    "chai-as-promised": "8.0.2",
    "chai-string": "2.0.0",
    "del-cli": "7.0.0",
    "mocha": "11.7.5",
    "shebang-trim": "1.3.0",
    "tsx": "4.21.0"
  },
  "mocha": {
    "extension": [
      "ts"
    ],
    "import": "tsx"
  }
}
